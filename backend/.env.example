# Backend Environment Variables
# Copy this to .env for local development
# Set these in Render Dashboard > Environment for production

# Database - get from Neon/Supabase/PlanetScale
DATABASE_URL="mysql://user:password@host:3306/mediapipeline"

# Redis - get from Upstash
REDIS_HOST="your-upstash-host.upstash.io"
REDIS_PORT=6379

# Frontend URL for CORS (your Vercel URL)
FRONTEND_URL="https://your-app.vercel.app"

PORT=3000
