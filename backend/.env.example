# Backend Environment Variables
# Set these in Render Dashboard > Environment for production

# Database - use PUBLIC URL from Railway (not the internal one)
DATABASE_URL="mysql://root:PASSWORD@HOST.railway.app:PORT/railway"

# Redis - paste the full URL from Upstash > Details > "REDIS_URL"
REDIS_URL="redis://default:PASSWORD@evolving-wombat-XXXX.upstash.io:6379"

# Frontend URL for CORS - your Vercel deployment URL
FRONTEND_URL="https://your-app.vercel.app"

PORT=3000
