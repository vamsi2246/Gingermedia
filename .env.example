# ============================================
# Vehicle Media Processing Pipeline
# Environment Configuration
# ============================================

# Server
NODE_ENV=development
PORT=3000

# MySQL Database (Prisma)
DATABASE_URL="mysql://root:rootpassword@localhost:3306/vehicle_pipeline"

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# Worker Configuration
WORKER_CONCURRENCY=3
JOB_MAX_RETRIES=3
JOB_RETRY_DELAY=5000

# Duplicate Detection
HASH_DISTANCE_THRESHOLD=10

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
